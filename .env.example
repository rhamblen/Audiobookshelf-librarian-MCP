# Audiobookshelf instance
ABS_URL=http://192.168.1.100:13378
ABS_TOKEN=your-abs-api-token-here

# Colon-separated paths inside the container where your audiobooks are mounted
LIBRARY_ROOTS=/audiobooks

# Where duplicates / unwanted files are moved (never deleted)
QUARANTINE_DIR=/quarantine

# Static bearer token that Claude uses to authenticate to this MCP server
MCP_TOKEN=change-me-to-a-long-random-string

# Safety: dry-run is ON by default; each tool call must pass confirm=true to execute
DRY_RUN_DEFAULT=true

# Port the MCP server listens on
PORT=8000

# Path for the JSON-lines audit log (inside the mounted volume so it persists)
AUDIT_LOG=/audiobooks/.abs-librarian-audit.jsonl

# detect_blobs defaults (overridable per tool call)
BLOB_HOURS_THRESHOLD=6.0
BLOB_FILE_COUNT_THRESHOLD=10
